{
  "include": ["$(MODULES)/pins/digital/manifest.json"],
  "defines": {
    "st77916": {
      "width": 360,
      "height": 360,
      "hz": 40000000,
      "column_offset": 0,
      "row_offset": 0
    },
    "poco": {
      "dma": 1
    }
  },
  "modules": {
    "*": "./*",
    "commodetto/Bitmap": "$(COMMODETTO)/commodettoBitmap"
  },
  "preload": ["st77916", "commodetto/Bitmap"],
  "platforms": {
    "esp32": {
      "dependency": [{ "idf": "esp_lcd" }]
    }
  }
}
