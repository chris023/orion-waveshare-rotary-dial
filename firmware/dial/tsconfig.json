{
  "compilerOptions": {
    "target": "ES2024",
    "module": "es2022",
    "moduleResolution": "node",
    "lib": ["es2024"],
    "types": [],
    "typeRoots": ["./node_modules/@moddable/typings", "./node_modules/@types"],
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["main.ts", "src/**/*.ts"]
}
