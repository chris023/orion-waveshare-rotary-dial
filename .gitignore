# Dependencies
node_modules/

# Build output
dist/
dist-simulator/
*.tsbuildinfo

# Test / coverage
coverage/

# Env & secrets (NEVER commit real Orion credentials or captures)
.env
.env.local
.env.*.local
secrets/
captures/
*.har
*.der

# Logs
*.log
logs/
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Device flash backups (per-unit dumps contain NVS data such as BT bonding keys
# and must never be published; keep them local-only)
firmware/backups/*.bin

# Archived experiments: never track their generated ESP-IDF/build output
archive/**/build/
archive/**/managed_components/
archive/**/sdkconfig
archive/**/sdkconfig.old
archive/**/dependencies.lock
