# Copy to .env and adjust. Load with: node --env-file=.env dist/main.js
# (tsx/dev also reads .env automatically). NEVER commit a real .env.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Wiring: which implementations to use ---
# DIAL_TRANSPORT: how the physical dials talk to this hub. "mock" needs no
# hardware/broker (great for dev + CI); "mqtt" connects to a real MQTT broker.
DIAL_TRANSPORT=mock
# DEVICE_CLIENT: what the hub controls. "fake" is an in-memory topper simulator;
# "orion" is the real Orion Sleep client via its MCP server (run `npm run
# orion:login` once first — see docs/ORION_MCP.md).
DEVICE_CLIENT=fake

# --- MQTT (used when DIAL_TRANSPORT=mqtt) ---
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=orion-dials
# BROKER_MODE=embedded starts an in-process MQTT broker (aedes) so the ESP32
# dials can connect to THIS host with no external broker. "none" = use MQTT_URL.
BROKER_MODE=none
BROKER_PORT=1883
# WebSocket MQTT port for browser dials (the simulator). 0 = off.
BROKER_WS_PORT=8888

# --- Orion Sleep MCP (used when DEVICE_CLIENT=orion; see docs/ORION_MCP.md) ---
ORION_MCP_URL=https://mcp.orionsleep.com/
# Loopback port used only during the one-time `npm run orion:login`.
ORION_OAUTH_PORT=8788
# Where the OAuth client registration + tokens are persisted (gitignored).
ORION_TOKENS_FILE=./secrets/orion-oauth.json
# Optional JSON overriding the MCP tool-name map (see src/device/orion/tool-map.ts).
# ORION_TOOLS={"setZone":"set_zone","getState":"get_device_state"}

# --- Behaviour tuning ---
# How often to poll the topper for state to refresh the dial displays (ms).
POLL_INTERVAL_MS=15000
# Coalesce rapid knob turns into a single write after this quiet period (ms).
WRITE_DEBOUNCE_MS=300
# Dial temperature bounds/step in °F (device range is 50-113°F / 10-45°C).
TEMP_MIN_F=50
TEMP_MAX_F=113
TEMP_STEP_F=1

# --- Dial -> zone mapping (JSON array) ---
# Which physical dial controls which device zone. Omit to use the built-in
# default (dial-left -> left, dial-right -> right on device "orion-1").
# DIAL_BINDINGS=[{"dialId":"dial-left","deviceId":"orion-1","zone":"left","label":"LEFT"},{"dialId":"dial-right","deviceId":"orion-1","zone":"right","label":"RIGHT"}]
