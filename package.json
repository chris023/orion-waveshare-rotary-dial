{
  "name": "orion-waveshare-rotary-dial",
  "version": "0.1.0",
  "private": true,
  "description": "Bridge that lets physical Waveshare ESP32-S3 rotary knob dials control an Orion Sleep dual-zone liquid-cooled mattress topper.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "orion:login": "tsx src/cli/orion-login.ts",
    "orion:tools": "tsx src/cli/orion-tools.ts",
    "dial:ref": "tsx firmware/reference-dial/dial.ts",
    "sim": "vite",
    "hub:sim": "DIAL_TRANSPORT=mqtt BROKER_MODE=embedded DEVICE_CLIENT=fake LOG_LEVEL=debug tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "orion-sleep",
    "mattress-topper",
    "waveshare",
    "esp32-s3",
    "rotary-encoder",
    "mqtt",
    "home-automation",
    "typescript"
  ],
  "author": "Chris Meyer",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aedes": "^1.1.1",
    "mqtt": "^5.15.2",
    "pino": "^10.3.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
